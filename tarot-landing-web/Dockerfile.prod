FROM node:22-alpine AS build

ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

WORKDIR /app

# 1. ONLY copy package.json (forget the lockfiles!)
COPY package.json ./

# 2. Force install directly inside the container 
# This auto-fetches the correct alpine binaries natively
RUN npm install

# 3. Copy the rest of the source code
COPY . .

# 4. Build it
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]